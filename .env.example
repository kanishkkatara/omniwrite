# ────────────────────────────────────────────────
# LLM API Keys — add at least one pair
# ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional providers (uncomment to enable)
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# MISTRAL_API_KEY=...
# TOGETHER_API_KEY=...
# COHERE_API_KEY=...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ────────────────────────────────────────────────
# Search Providers (at least one recommended)
# ────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...           # https://tavily.com (recommended)
# BRAVE_SEARCH_API_KEY=...        # https://brave.com/search/api/

# ────────────────────────────────────────────────
# Publishing Integrations (all optional)
# ────────────────────────────────────────────────
# Ghost CMS
# GHOST_URL=https://yourblog.ghost.io
# GHOST_ADMIN_KEY=...

# Hashnode
# HASHNODE_TOKEN=...
# HASHNODE_PUB_ID=...

# WordPress
# WORDPRESS_URL=https://yourblog.com
# WORDPRESS_USER=admin
# WORDPRESS_APP_PASSWORD=...

# Dev.to
# DEVTO_API_KEY=...

# Notion
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=...

# ────────────────────────────────────────────────
# Observability (optional)
# ────────────────────────────────────────────────
# LangSmith tracing
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=omniwrite

# ────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────
# Path to your config.yaml (defaults to ./config.yaml)
# OMNIWRITE_CONFIG=./config.yaml

# Default model mode: test | production
# OMNIWRITE_DEFAULT_MODE=test

# Set to true to enable verbose agent logging
# OMNIWRITE_DEBUG=false
